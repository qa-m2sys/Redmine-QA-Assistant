{
  "manifest_version": 3,
  "name": "QA Assistant for Redmine",
  "version": "6.3.0",
  "description": "Report Redmine issues in any tracker with per-tracker templates, an AI report assistant, and a draggable/dockable panel.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "QA Assistant for Redmine",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": ["https://api.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://redmine.kernello.com/*", "https://dev.cloudapper.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
